# Telegram API
API_ID=1234567
API_HASH=your_api_hash

# Admin Bot
BOT_TOKEN=your_bot_token_here
ADMIN_ID=111111111

# Proxy (опционально)
# PROXY_ENABLED=true
# PROXY_HOST=127.0.0.1
# PROXY_PORT=1080

# Schedule (24h формат, московское время)
WORK_START_HOUR=8
WORK_END_HOUR=22
TIMEZONE=Europe/Moscow

# Rate limit
RATE_LIMIT_MESSAGES=20
RATE_LIMIT_PERIOD=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=bot.log
